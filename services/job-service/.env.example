# Job Service
PORT=3002
NODE_ENV=development

# MySQL (used by seed loader and future API)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# Copy to .env and set your real password (never commit .env)
MYSQL_PASSWORD=
MYSQL_DATABASE=data236

# Kaggle / seed — e.g. ./data/job_postings.csv (see docs/job-seed-mapping.md). Use SEED_MAX_ROWS while testing.
JOBS_CSV_PATH=./data/job_postings.csv
SEED_BATCH_SIZE=500
SEED_MAX_ROWS=

# Kafka (W2+) — omit KAFKA_BROKERS to disable producer + consumer locally
# KAFKA_BROKERS=127.0.0.1:9092
# KAFKA_CLIENT_ID=job-service
# KAFKA_TOPIC_JOB_CREATED=job.created
# KAFKA_TOPIC_APPLICATION_SUBMITTED=application.submitted
# KAFKA_GROUP_APPLICATION_SUBMITTED=job-service-application-submitted
# KAFKA_AUTO_CREATE_TOPICS=true
# KAFKA_IDEMPOTENCY_NAMESPACE=a0000001-0000-5000-8000-000000000001
