# Job Service
PORT=3002
NODE_ENV=development

# MySQL (used by seed loader and future API)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# Copy to .env and set your real password (never commit .env)
MYSQL_PASSWORD=
MYSQL_DATABASE=data236

# Kaggle / seed — path to LinkedIn Jobs 2023 CSV (see docs/job-seed-mapping.md)
JOBS_CSV_PATH=./data/linkedin_jobs.csv
SEED_BATCH_SIZE=500
SEED_MAX_ROWS=
